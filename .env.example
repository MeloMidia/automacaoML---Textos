# Chave da API do Groq (modelos llama, mixtral etc.)
GROQ_API_KEY=sua_chave_groq_aqui

# Chave da API do Google AI Studio (modelo Gemini) — obtenha em aistudio.google.com
GOOGLE_API_KEY=sua_chave_google_aqui

# Modelos para rotação automática (separados por vírgula) — quando um esgota, passa pro próximo
# Modelos "gemini*" usam a API do Google; os demais usam o Groq
# Deixe em branco para usar a lista padrão embutida no código
# MODELOS=gemini-2.5-flash-lite,llama-3.3-70b-versatile,llama-3.1-8b-instant

# Credenciais de acesso à interface web
APP_USER=timemelo
APP_PASSWORD=123456
# Token do Google OAuth2 (gerado pelo comando abaixo — veja DEPLOY.md)
TOKEN_PICKLE_

# Chave secreta para assinar o cookie de sessão (gere uma aleatória)
# PowerShell: -join ((65..90)+(97..122)+(48..57) | Get-Random -Count 40 | % {[char]$_})
SECRET_KEY=troque_por_uma_chave_aleatoria_longa
